select count(*), department from corporate_team
group by department;

select round(avg(salary),0) as SALARY, department from corporate_team
group by department;

select min(age), max(age), department from corporate_team
group by department;

SELECT MAX(Salary), department FROM corporate_team
GROUP BY department
order by max(salary) desc;

SELECT SUM(Salary) as total_payroll, department
from corporate_team
GROUP BY department;

SELECT round(AVG(Salary),0), department 
FROM corporate_team
GROUP BY department;

SELECT COUNT(*), department
FROM corporate_team
group by department
having Count(*) < 3;

Select department FROM corporate_team
group by department
having sum(salary) > 150000
order by sum(salary) desc;


Select department, (max(salary) - min(salary)) as salary_difference
from corporate_team
group by department;